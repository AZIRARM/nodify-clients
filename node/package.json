{
  "name": "nodify-node-client",
  "version": "1.0.3",
  "description": "Node client for Nodify Headless CMS",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist",
    "test": "ts-node src/example/nodify-tests.ts"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "keywords": ["nodify", "cms", "headless-cms", "client", "typescript"],
  "author": "Azirar Mhamed",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "acorn": "^8.15.0",
    "acorn-walk": "^8.3.4",
    "arg": "^4.1.3",
    "create-require": "^1.1.1",
    "diff": "^4.0.4",
    "make-error": "^1.3.6",
    "undici-types": "^7.16.0",
    "v8-compile-cache-lib": "^3.0.1",
    "yn": "^3.1.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AZIRARM/nodify-clients.git"
  },
  "bugs": {
    "url": "https://github.com/AZIRARM/nodify-clients/issues"
  },
  "homepage": "https://github.com/AZIRARM/nodify-clients#readme"
}